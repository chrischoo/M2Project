GOOGLE_APPLICATION_CREDENTIALS=

# Matches ${GCP_PROJECT_ID} in your meltano.yml
GCP_PROJECT_ID=

# Explicitly overrides the target-bigquery dataset_id setting natively
TARGET_BIGQUERY_DATASET_ID=raw_olist
TARGET_BIGQUERY_DATASET_ID_DB=raw_olist

# Keep your other pipeline variables
GCS_BUCKET_NAME=sme-olist-data-lake
LOCAL_CSV_DIR=./dataset